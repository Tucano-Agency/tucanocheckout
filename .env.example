# PostgreSQL (Drizzle / postgres.js)
# Local:
# DATABASE_URL=postgresql://user:pass@localhost:5432/tucano_checkout
#
# Supabase (Dashboard → Project Settings → Database):
# 1) Migrações no seu Mac: use "Direct connection" (URI com host db.<ref>.supabase.co:5432).
#    Rode: npm run db:migrate
# 2) App na Vercel/serverless: use "Transaction pooler" (porta 6543 / host *.pooler.supabase.com).
#    O client detecta pooler e usa prepare:false automaticamente.
# Opcional: mais conexões só em runtime Node long-lived (não aumente em serverless).
# DATABASE_POOL_MAX=1
DATABASE_URL=

# Chave mestra para AES-256-GCM em tenant_gateways.encrypted_credential_blob (32 bytes em base64)
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TUCANO_GATEWAY_MASTER_KEY=

# Opcional: base da API Pagar.me (padrão https://api.pagar.me/core/v5)
# PAGARME_API_BASE_URL=

# Webhooks gateway → checkout (opcional — se omitido, aceita POST sem auth em dev)
# URL no painel Asaas: https://seu-dominio/api/webhooks/asaas
# ASAAS_WEBHOOK_ACCESS_TOKEN=
# PAGARME_WEBHOOK_USER=
# PAGARME_WEBHOOK_PASSWORD=

# Encaminhar eventos canônicos para o núcleo Tucano (opcional)
# TUCANO_PLATFORM_WEBHOOK_URL=
# TUCANO_PLATFORM_WEBHOOK_SECRET=

# Painel admin do produtor (mín. 16 caracteres)
TUCANO_ADMIN_SECRET=
